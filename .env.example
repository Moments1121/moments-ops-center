# ============================================================
# MOMENTS HOSPICE OPS CENTER — CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# --- TABLEAU ---
# Your HCHB Tableau server (already confirmed: basrv-tx.hchb.com)
TABLEAU_SERVER=https://basrv-tx.hchb.com
TABLEAU_SITE_ID=Moments
# Create a Personal Access Token in Tableau:
# My Account > Settings > Personal Access Tokens > Create token
TABLEAU_TOKEN_NAME=your-token-name-here
TABLEAU_TOKEN_VALUE=your-token-value-here

# --- ZENDESK ---
# Your Zendesk subdomain (e.g. if URL is momentshospice.zendesk.com, use: momentshospice)
ZENDESK_SUBDOMAIN=your-subdomain-here
# Your Zendesk email address
ZENDESK_EMAIL=your-email@momentshospice.com
# Zendesk API token: Admin > Channels > API > API Token
ZENDESK_API_TOKEN=your-zendesk-api-token-here

# --- MICROSOFT 365 (for email scanning) ---
# Register an app at portal.azure.com > Azure Active Directory > App registrations
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
# The email address whose inbox to scan for resignations/alerts
MICROSOFT_MAILBOX=your-email@momentshospice.com

# --- ANTHROPIC (for AI summaries) ---
# Get from console.anthropic.com > API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- APP SETTINGS ---
# How often to refresh data (in minutes). Default: 30
REFRESH_INTERVAL_MINUTES=30
# Port to run the server on
PORT=3000
# Send daily email digest? (true/false)
SEND_EMAIL_DIGEST=true
# What time to send the daily digest (24hr format, your timezone)
DIGEST_TIME=06:30
# Who gets the daily digest email
DIGEST_RECIPIENTS=sol@momentshospice.com
